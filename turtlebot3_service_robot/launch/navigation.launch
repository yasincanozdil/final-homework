<!-- navigation.launch
     AMCL lokalizasyon + move_base navigasyon başlatır.

     Kullanım:
       roslaunch turtlebot3_service_robot navigation.launch
     
     RViz açıldığında:
       1. "2D Pose Estimate" ile robotu haritada konumlandırın.
       2. Robot lokalize olunca task_manager başlatabilirsiniz.
-->
<launch>

  <arg name="model"      default="burger"/>
  <arg name="map_file"
       default="$(find turtlebot3_service_robot)/maps/map.yaml"/>
  <arg name="open_rviz"  default="true"/>
  <arg name="move_forward_only" default="false"/>

  <param name="tb3_model" value="$(arg model)"/>

  <!-- Harita sunucusu -->
  <node pkg="map_server" name="map_server" type="map_server"
        args="$(arg map_file)"/>

  <!-- AMCL lokalizasyon -->
  <include file="$(find turtlebot3_navigation)/launch/amcl.launch"/>

  <!-- move_base -->
  <include file="$(find turtlebot3_navigation)/launch/move_base.launch">
    <arg name="model"             value="$(arg model)"/>
    <arg name="move_forward_only" value="$(arg move_forward_only)"/>
  </include>

  <!-- RViz -->
  <group if="$(arg open_rviz)">
    <node pkg="rviz" type="rviz" name="rviz"
          args="-d $(find turtlebot3_navigation)/rviz/turtlebot3_navigation.rviz"/>
  </group>

</launch>
